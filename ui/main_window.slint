import { StackView, ListView, HorizontalBox, VerticalBox, GridBox, LineEdit, Button, TextEdit, Label, Slider, ComboBox, ProgressIndicator, Switch, ScrollView, CheckBox, Tab, TabWidget, ProgressBar, Palette, Colors, StandardButton, Dialog, GroupBox } from "std-widgets.slint";

component MessageBubble {
    in property <string> role;
    in property <string> content;
    in property <bool> is-user: role == "user";
    
    Rectangle {
        background: is-user ? #2D2D2E : #1E1E2E;
        border-radius: 16px;
        border-width: 1px;
        border-color: is-user ? #3D3D3E : #2E2E4E;
        padding: 10px 14px;
        max-width: 460px;
    }
    
    VerticalLayout {
        spacing: 4px;
        padding: 0;
        
        Label {
            text: is-user ? "You 🗣" : "Sensei 🎓";
            font-size: 11px;
            font-weight: 700;
            color: is-user ? #81C784 : #FFD54F;
        }
        
        Label {
            text: content;
            font-size: 14px;
            color: #FFFFFF;
            wrap: true;
            horizontal-align: is-user ? right : left;
        }
        
        HorizontalLayout {
            visible: !is-user;
            spacing: 8px;
            padding-top: 6px;
            
            Button {
                text: "🔊 Play";
                font-size: 11px;
                height: 26px;
                background: #607D8B;
                border-radius: 8px;
                clicked => { root.play-audio(content); }
            }
            
            Button {
                text: "🔄 Translate";
                font-size: 11px;
                height: 26px;
                background: #607D8B;
                border-radius: 8px;
                clicked => { root.translate(content); }
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "日本語 Sensei — Japanese Language Tutor";
    width: 1020px;
    height: 850px;
    min-width: 800px;
    min-height: 600px;
    resizable: true;
    
    // Colors matching the original app
    property <color> bg-dark: #161618;
    property <color> bg-secondary: #0D0D0E;
    property <color> accent-primary: #6366F1;
    property <color> accent-green: #81C784;
    property <color> accent-gold: #FFD54F;
    property <color> accent-red: #E57373;
    property <color> text-primary: #FFFFFF;
    property <color> text-secondary: #94A3B8;
    property <color> send-btn: #2196F3;
    property <color> ptt-ready: #4CAF50;
    property <color> ptt-recording: #F44336;
    property <color> user-bubble: #2D2D2E;
    property <color> assistant-bubble: #1E1E2E;
    
    // State
    property <bool> is-recording: false;
    property <bool> is-processing: false;
    property <bool> tts-enabled: true;
    property <string> status-text: "⏳ Initializing...";
    property <string> current-level: "A0.1";
    property <int> japanese-ratio: 70;
    property <string> api-key: "";
    
    // Callbacks
    callback send-message(string);
    callback start-recording();
    callback stop-recording();
    callback play-audio(string);
    callback translate(string);
    callback clear-chat();
    callback save-api-key(string);
    callback change-level(string);
    callback change-ratio(int);
    callback toggle-tts();
    callback load-sessions();
    callback load-session(string);
    callback delete-session(string);
    callback refresh-vocab();
    
    // Internal callbacks
    callback add-message(string, string);
    callback clear-messages();
    callback set-status(string);
    callback show-translation(string, string);
    callback update-sessions([{id: string, level: string, started: string, message_count: int, preview: string}]);
    callback update-vocabulary([{word: string, reading: string, struggles: int, next_review: string, level: int, is_due: bool}]);
    callback set-recording-state(bool);
    
    VerticalLayout {
        spacing: 0;
        padding: 0;
        
        // Header
        Rectangle {
            background: bg-secondary;
            height: 160px;
            
            VerticalLayout {
                spacing: 8px;
                padding: 16px 22px;
                
                // Title
                HorizontalLayout {
                    spacing: 0;
                    
                    Label {
                        text: "日本語";
                        font-size: 32px;
                        font-weight: 700;
                        color: accent-red;
                    }
                    Label {
                        text: " Sensei";
                        font-size: 32px;
                        font-weight: 700;
                        color: text-primary;
                    }
                    Label {
                        text: " 🎌 Immersive Japanese Tutor";
                        font-size: 13px;
                        color: text-secondary;
                    }
                }
                
                // Controls row
                HorizontalLayout {
                    spacing: 12px;
                    VerticalLayout {
                        HorizontalLayout {
                            spacing: 6px;
                            Label { text: "🎙 Mic:"; font-size: 13px; font-weight: 700; color: text-primary; }
                            ComboBox {
                                width: 200px;
                                model: ["Default Microphone", "Built-in Microphone"];
                            }
                        }
                    }
                    
                    VerticalLayout {
                        HorizontalLayout {
                            spacing: 6px;
                            Label { text: "🗣 Speak:"; font-size: 13px; font-weight: 700; color: text-primary; }
                            ComboBox {
                                width: 130px;
                                model: ["🇯🇵 Japanese", "🇬🇧 English", "🌐 Auto"];
                            }
                        }
                    }
                    
                    VerticalLayout {
                        HorizontalLayout {
                            spacing: 6px;
                            Label { text: "📚 Level:"; font-size: 13px; font-weight: 700; color: text-primary; }
                            ComboBox {
                                width: 110px;
                                model: ["A0.1", "A0.2", "A0.3", "Beginner", "Elementary", "N5", "N4", "N3", "N2", "N1", "Any Level"];
                                selected => { change-level(self.selected); }
                            }
                        }
                    }
                    
                    Button {
                        text: "📂";
                        width: 36px;
                        height: 30px;
                        background: #607D8B;
                        clicked => { load-sessions(); }
                    }
                    
                    Button {
                        text: "🗑";
                        width: 36px;
                        height: 30px;
                        background: #f44336;
                        clicked => { clear-chat(); }
                    }
                }
                
                Rectangle { height: 1px; background: #1c1c3a; }
                
                // TTS and ratio controls
                HorizontalLayout {
                    spacing: 20px;
                    
                    HorizontalLayout {
                        spacing: 6px;
                        Label { text: "🔊 Voice:"; font-size: 13px; font-weight: 700; color: text-primary; }
                        Button {
                            text: tts-enabled ? "🔊 ON" : "🔇 OFF";
                            width: 100px;
                            height: 30px;
                            background: tts-enabled ? ptt-ready : #607D8B;
                            clicked => { toggle-tts(); }
                        }
                    }
                    
                    ComboBox {
                        width: 160px;
                        model: ["Nanami 👩 (Female)", "Keita 👨 (Male)"];
                    }
                    
                    ComboBox {
                        width: 100px;
                        model: ["Very Slow", "Slow", "Normal", "Fast", "Very Fast"];
                    }
                    
                    Rectangle { width: 40px; }
                    
                    HorizontalLayout {
                        spacing: 8px;
                        Label { text: "🇯🇵 Japanese ratio:"; font-size: 12px; font-weight: 700; color: text-primary; }
                        Label { 
                            text: "70% JP / 30% EN"; 
                            font-size: 12px; 
                            color: accent-gold;
                            width: 130px;
                        }
                        Slider {
                            minimum: 50;
                            maximum: 100;
                            value: 70;
                            width: 200px;
                            changed(v) => { change-ratio(v); }
                        }
                        Label { text: "50/50"; font-size: 10px; color: text-secondary; }
                        Label { text: "100% JP"; font-size: 10px; color: text-secondary; }
                    }
                }
            }
        }
        
        // Tab Widget
        TabWidget {
            Tab {
                title: "💬 Chat";
                
                VerticalLayout {
                    spacing: 0;
                    padding: 0;
                    
                    // Chat messages
                    ScrollView {
                        vertical-scrollbar-mode: auto;
                        
                        ListView {
                            property <[{role: string, content: string}]> messages: [];
                            spacing: 10px;
                            padding: 10px;
                            
                            for msg in messages: MessageBubble {
                                role: msg.role;
                                content: msg.content;
                            }
                        }
                    }
                    
                    // Input area
                    Rectangle {
                        background: bg-secondary;
                        height: 130px;
                        padding: 8px 20px;
                        
                        VerticalLayout {
                            spacing: 8px;
                            
                            HorizontalLayout {
                                spacing: 8px;
                                
                                LineEdit {
                                    placeholder-text: "✍ Type in Japanese or English...";
                                    height: 44px;
                                    font-size: 14px;
                                    border-radius: 10px;
                                    accepted(text) => { send-message(text); self.text = ""; }
                                }
                                
                                Button {
                                    text: "Send ➤";
                                    width: 90px;
                                    height: 44px;
                                    font-size: 13px;
                                    font-weight: 700;
                                    background: send-btn;
                                    border-radius: 10px;
                                    clicked => { send-message(parent.parent.children[0].text); parent.parent.children[0].text = ""; }
                                }
                            }
                            
                            // PTT Button
                            Button {
                                text: is-recording ? "🔴 Recording..." : "🎤 Hold to Speak";
                                height: 60px;
                                font-size: 20px;
                                font-weight: 700;
                                background: is-recording ? ptt-recording : ptt-ready;
                                border-radius: 14px;
                                border-width: 2px;
                                border-color: is-recording ? #e57373 : #81C784;
                                
                                pressed => { start-recording(); }
                                released => { stop-recording(); }
                            }
                        }
                    }
                }
            }
            
            Tab {
                title: "📖 Session Review";
                
                VerticalLayout {
                    spacing: 10px;
                    padding: 10px;
                    
                    Label {
                        text: "📖 Session Review";
                        font-size: 16px;
                        font-weight: 700;
                        color: text-primary;
                    }
                    
                    ScrollView {
                        vertical-scrollbar-mode: auto;
                        
                        VerticalBox {
                            property <[{id: string, level: string, started: string, message_count: int, preview: string}]> sessions: [];
                            
                            for sess in sessions: Rectangle {
                                background: assistant-bubble;
                                border-radius: 10px;
                                padding: 10px 12px;
                                
                                VerticalLayout {
                                    spacing: 4px;
                                    
                                    HorizontalLayout {
                                        Label { text: "🗓 " + sess.started; font-size: 12px; font-weight: 700; color: text-primary; }
                                        Label { text: "📚 " + sess.level; font-size: 11px; font-weight: 700; color: accent-gold; }
                                        Label { text: "💬 " + sess.message_count + " msgs"; font-size: 11px; color: text-secondary; }
                                    }
                                    
                                    Label { 
                                        text: "\"" + sess.preview + "\""; 
                                        font-size: 11px; 
                                        color: text-secondary;
                                        wrap: true;
                                    }
                                    
                                    HorizontalLayout {
                                        spacing: 8px;
                                        Button {
                                            text: "▶ Load";
                                            width: 80px;
                                            height: 28px;
                                            font-size: 11px;
                                            font-weight: 700;
                                            background: send-btn;
                                            clicked => { load-session(sess.id); }
                                        }
                                        Button {
                                            text: "🗑 Delete";
                                            width: 80px;
                                            height: 28px;
                                            font-size: 11px;
                                            background: accent-red;
                                            clicked => { delete-session(sess.id); }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
            
            Tab {
                title: "📊 Vocabulary";
                
                VerticalLayout {
                    spacing: 10px;
                    padding: 10px;
                    
                    Label {
                        text: "📊 Tracked Vocabulary (Spaced Repetition)";
                        font-size: 15px;
                        font-weight: 700;
                        color: text-primary;
                    }
                    
                    ScrollView {
                        vertical-scrollbar-mode: auto;
                        
                        VerticalBox {
                            property <[{word: string, reading: string, struggles: int, next_review: string, level: int, is_due: bool}]> vocab: [];
                            
                            // Header
                            HorizontalLayout {
                                Label { text: "Word"; font-size: 11px; font-weight: 700; color: text-secondary; }
                                Label { text: "Reading"; font-size: 11px; font-weight: 700; color: text-secondary; }
                                Label { text: "Struggles"; font-size: 11px; font-weight: 700; color: text-secondary; }
                                Label { text: "Next Review"; font-size: 11px; font-weight: 700; color: text-secondary; }
                            }
                            
                            for word in vocab: Rectangle {
                                background: word.is_due ? #1a1a10 : transparent;
                                border-radius: 4px;
                                padding: 4px;
                                
                                HorizontalLayout {
                                    Label { 
                                        text: word.word; 
                                        font-size: 12px; 
                                        color: word.is_due ? accent-gold : text-primary; 
                                    }
                                    Label { text: word.reading; font-size: 12px; color: text-secondary; }
                                    Label { text: word.struggles; font-size: 12px; color: text-secondary; }
                                    Label { text: word.next_review; font-size: 12px; color: text-secondary; }
                                }
                            }
                        }
                    }
                }
            }
            
            Tab {
                title: "⚙️ Settings";
                
                VerticalLayout {
                    spacing: 20px;
                    padding: 20px;
                    
                    VerticalBox {
                        spacing: 15px;
                        
                        Label { text: "🔑 Groq API Key"; font-size: 14px; font-weight: 700; color: text-primary; }
                        
                        LineEdit {
                            placeholder-text: "gsk_...";
                            password: true;
                            height: 44px;
                            font-size: 14px;
                            accepted(text) => { save-api-key(text); }
                        }
                        
                        Label { 
                            text: "Get a free key → console.groq.com/keys"; 
                            font-size: 11px; 
                            color: accent-green; 
                        }
                        
                        Rectangle { height: 1px; background: #1c1c3a; }
                        
                        Label { text: "🎛 Engine Settings"; font-size: 14px; font-weight: 700; color: text-primary; }
                        
                        Label { text: "Whisper Model: medium (configurable)"; font-size: 12px; color: text-secondary; }
                        
                        Label { text: "Transcription Language: Japanese"; font-size: 12px; color: text-secondary; }
                        
                        Label { text: "Device: auto (GPU if available)"; font-size: 12px; color: text-secondary; }
                    }
                }
            }
        }
        
        // Status bar
        Rectangle {
            background: #1a1a1a;
            height: 28px;
            
            HorizontalLayout {
                padding: 0 16px;
                
                Label {
                    text: status-text;
                    font-size: 11px;
                    color: text-secondary;
                    horizontal-align: left;
                }
                
                Rectangle { width: 1px; }
                
                Label {
                    text: "Whisper medium • LLM llama-3.3-70b • TTS VOICEVOX • 70/30 ratio";
                    font-size: 10px;
                    color: #444466;
                    horizontal-align: right;
                }
            }
        }
    }
}
