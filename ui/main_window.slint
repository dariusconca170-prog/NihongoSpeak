import { ListView, HorizontalBox, VerticalBox, GridBox, LineEdit, Button, TextEdit, Slider, ComboBox, ScrollView, CheckBox, StandardButton, GroupBox, Palette } from "std-widgets.slint";

component MessageBubble inherits Rectangle {
    in property <string> role;
    in property <string> content;
    in property <bool> is-user: role == "user";

    callback play-audio-requested(string);
    callback translate-requested(string);

    background: is-user ? #2D2D2E : #1E1E2E;
    border-radius: 16px;
    border-width: 1px;
    border-color: is-user ? #3D3D3E : #2E2E4E;
    padding-left: 14px;
    padding-right: 14px;
    padding-top: 10px;
    padding-bottom: 10px;
    max-width: 460px;
    height: inner-layout.preferred-height + 20px;

    inner-layout := VerticalLayout {
        spacing: 4px;
        padding: 0;

        Text {
            text: is-user ? "You 🗣" : "Sensei 🎓";
            font-size: 11px;
            font-weight: 700;
            color: is-user ? #81C784 : #FFD54F;
        }

        Text {
            text: content;
            font-size: 14px;
            color: #FFFFFF;
            wrap: word-wrap;
            horizontal-alignment: is-user ? right : left;
        }

        if !is-user : HorizontalLayout {
            spacing: 8px;
            padding-top: 6px;

            Button {
                text: "🔊 Play";
                height: 26px;
                clicked => { play-audio-requested(content); }
            }

            Button {
                text: "🔄 Translate";
                height: 26px;
                clicked => { translate-requested(content); }
            }
        }
    }
}

struct MessageData {
    role: string,
    content: string,
}

struct SessionData {
    id: string,
    level: string,
    started: string,
    message-count: int,
    preview: string,
}

struct VocabData {
    word: string,
    reading: string,
    struggles: int,
    next-review: string,
    level: int,
    is-due: bool,
}

export component MainWindow inherits Window {
    title: "日本語 Sensei — Japanese Language Tutor";
    width: 1020px;
    height: 850px;
    min-width: 800px;
    min-height: 600px;

    // Colors matching the original app
    property <color> bg-dark: #161618;
    property <color> bg-secondary: #0D0D0E;
    property <color> accent-primary: #6366F1;
    property <color> accent-green: #81C784;
    property <color> accent-gold: #FFD54F;
    property <color> accent-red: #E57373;
    property <color> text-primary: #FFFFFF;
    property <color> text-secondary: #94A3B8;
    property <color> send-btn-color: #2196F3;
    property <color> ptt-ready: #4CAF50;
    property <color> ptt-recording: #F44336;
    property <color> user-bubble: #2D2D2E;
    property <color> assistant-bubble: #1E1E2E;

    // State
    in-out property <bool> is-recording: false;
    in-out property <bool> is-processing: false;
    in-out property <bool> tts-enabled: true;
    in-out property <string> status-text: "⏳ Initializing...";
    in-out property <string> current-level: "A0.1";
    in-out property <int> japanese-ratio: 70;
    in-out property <string> api-key: "";
    in-out property <[MessageData]> messages: [];
    in-out property <[SessionData]> sessions: [];
    in-out property <[VocabData]> vocab: [];
    in-out property <int> current-tab: 0;
    in-out property <string> input-text: "";

    // Callbacks
    callback send-message(string);
    callback start-recording();
    callback stop-recording();
    callback play-audio(string);
    callback translate(string);
    callback clear-chat();
    callback save-api-key(string);
    callback change-level(string);
    callback change-ratio(int);
    callback toggle-tts();
    callback load-sessions();
    callback load-session(string);
    callback delete-session(string);
    callback refresh-vocab();

    background: bg-dark;

    VerticalLayout {
        spacing: 0;
        padding: 0;

        // Header
        Rectangle {
            background: bg-secondary;
            height: 160px;

            VerticalLayout {
                spacing: 8px;
                padding-left: 22px;
                padding-right: 22px;
                padding-top: 16px;
                padding-bottom: 16px;

                // Title
                HorizontalLayout {
                    spacing: 4px;
                    alignment: start;

                    Text {
                        text: "日本語";
                        font-size: 32px;
                        font-weight: 700;
                        color: accent-red;
                        vertical-alignment: center;
                    }
                    Text {
                        text: " Sensei";
                        font-size: 32px;
                        font-weight: 700;
                        color: text-primary;
                        vertical-alignment: center;
                    }
                    Text {
                        text: " 🎌 Immersive Japanese Tutor";
                        font-size: 13px;
                        color: text-secondary;
                        vertical-alignment: center;
                    }
                }

                // Controls row
                HorizontalLayout {
                    spacing: 12px;
                    alignment: start;

                    HorizontalLayout {
                        spacing: 6px;
                        Text { text: "🎙 Mic:"; font-size: 13px; font-weight: 700; color: text-primary; vertical-alignment: center; }
                        ComboBox {
                            width: 200px;
                            model: ["Default Microphone", "Built-in Microphone"];
                        }
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        Text { text: "🗣 Speak:"; font-size: 13px; font-weight: 700; color: text-primary; vertical-alignment: center; }
                        ComboBox {
                            width: 130px;
                            model: ["🇯🇵 Japanese", "🇬🇧 English", "🌐 Auto"];
                        }
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        Text { text: "📚 Level:"; font-size: 13px; font-weight: 700; color: text-primary; vertical-alignment: center; }
                        level-combo := ComboBox {
                            width: 110px;
                            model: ["A0.1", "A0.2", "A0.3", "Beginner", "Elementary", "N5", "N4", "N3", "N2", "N1", "Any Level"];
                            selected => { change-level(self.current-value); }
                        }
                    }

                    Button {
                        text: "📂";
                        width: 36px;
                        height: 30px;
                        clicked => { load-sessions(); }
                    }

                    Button {
                        text: "🗑";
                        width: 36px;
                        height: 30px;
                        clicked => { clear-chat(); }
                    }
                }

                Rectangle { height: 1px; background: #1c1c3a; }

                // TTS and ratio controls
                HorizontalLayout {
                    spacing: 20px;
                    alignment: start;

                    HorizontalLayout {
                        spacing: 6px;
                        Text { text: "🔊 Voice:"; font-size: 13px; font-weight: 700; color: text-primary; vertical-alignment: center; }
                        Button {
                            text: tts-enabled ? "🔊 ON" : "🔇 OFF";
                            width: 100px;
                            height: 30px;
                            clicked => { toggle-tts(); }
                        }
                    }

                    ComboBox {
                        width: 160px;
                        model: ["Nanami 👩 (Female)", "Keita 👨 (Male)"];
                    }

                    ComboBox {
                        width: 100px;
                        model: ["Very Slow", "Slow", "Normal", "Fast", "Very Fast"];
                    }

                    Rectangle { width: 40px; }

                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: "🇯🇵 Japanese ratio:"; font-size: 12px; font-weight: 700; color: text-primary; vertical-alignment: center; }
                        Text {
                            text: japanese-ratio + "% JP / " + (100 - japanese-ratio) + "% EN";
                            font-size: 12px;
                            color: accent-gold;
                            width: 130px;
                            vertical-alignment: center;
                        }
                        Slider {
                            minimum: 50;
                            maximum: 100;
                            value: 70;
                            width: 200px;
                            changed(v) => { root.japanese-ratio = round(v); change-ratio(round(v)); }
                        }
                        Text { text: "50/50"; font-size: 10px; color: text-secondary; vertical-alignment: center; }
                        Text { text: "100% JP"; font-size: 10px; color: text-secondary; vertical-alignment: center; }
                    }
                }
            }
        }

        // Tab bar (manual implementation since TabWidget/Tab don't exist in std-widgets)
        Rectangle {
            background: #1a1a2e;
            height: 40px;

            HorizontalLayout {
                spacing: 0;
                padding: 0;

                Rectangle {
                    background: current-tab == 0 ? accent-primary : transparent;
                    border-radius: 0;
                    height: 40px;
                    horizontal-stretch: 1;

                    Text {
                        text: "💬 Chat";
                        font-size: 13px;
                        font-weight: current-tab == 0 ? 700 : 400;
                        color: current-tab == 0 ? text-primary : text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        clicked => { current-tab = 0; }
                    }
                }

                Rectangle {
                    background: current-tab == 1 ? accent-primary : transparent;
                    height: 40px;
                    horizontal-stretch: 1;

                    Text {
                        text: "📖 Session Review";
                        font-size: 13px;
                        font-weight: current-tab == 1 ? 700 : 400;
                        color: current-tab == 1 ? text-primary : text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        clicked => { current-tab = 1; load-sessions(); }
                    }
                }

                Rectangle {
                    background: current-tab == 2 ? accent-primary : transparent;
                    height: 40px;
                    horizontal-stretch: 1;

                    Text {
                        text: "📊 Vocabulary";
                        font-size: 13px;
                        font-weight: current-tab == 2 ? 700 : 400;
                        color: current-tab == 2 ? text-primary : text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        clicked => { current-tab = 2; refresh-vocab(); }
                    }
                }

                Rectangle {
                    background: current-tab == 3 ? accent-primary : transparent;
                    height: 40px;
                    horizontal-stretch: 1;

                    Text {
                        text: "⚙️ Settings";
                        font-size: 13px;
                        font-weight: current-tab == 3 ? 700 : 400;
                        color: current-tab == 3 ? text-primary : text-secondary;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        clicked => { current-tab = 3; }
                    }
                }
            }
        }

        // Tab content area
        Rectangle {
            background: bg-dark;
            vertical-stretch: 1;

            // Chat Tab
            if current-tab == 0 : VerticalLayout {
                spacing: 0;
                padding: 0;

                // Chat messages
                ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 10px;
                        padding: 10px;
                        alignment: start;

                        for msg[i] in messages : MessageBubble {
                            role: msg.role;
                            content: msg.content;
                            play-audio-requested(text) => { root.play-audio(text); }
                            translate-requested(text) => { root.translate(text); }
                        }
                    }
                }

                // Input area
                Rectangle {
                    background: bg-secondary;
                    height: 130px;

                    VerticalLayout {
                        spacing: 8px;
                        padding-left: 20px;
                        padding-right: 20px;
                        padding-top: 8px;
                        padding-bottom: 8px;

                        HorizontalLayout {
                            spacing: 8px;

                            msg-input := LineEdit {
                                placeholder-text: "✍ Type in Japanese or English...";
                                height: 44px;
                                font-size: 14px;
                                horizontal-stretch: 1;
                                text <=> input-text;
                                accepted(text) => { 
                                    if text != "" {
                                        send-message(text); 
                                        input-text = ""; 
                                    }
                                }
                            }

                            Button {
                                text: "Send ➤";
                                width: 90px;
                                height: 44px;
                                clicked => {
                                    if input-text != "" {
                                        send-message(input-text);
                                        input-text = "";
                                    }
                                }
                            }
                        }

                        // PTT Button
                        ptt-btn := Rectangle {
                            height: 60px;
                            border-radius: 14px;
                            border-width: 2px;
                            border-color: is-recording ? #e57373 : #81C784;
                            background: is-recording ? ptt-recording : ptt-ready;

                            Text {
                                text: is-recording ? "🔴 Recording..." : "🎤 Hold to Speak";
                                font-size: 20px;
                                font-weight: 700;
                                color: white;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            TouchArea {
                                pointer-event(event) => {
                                    if event.kind == PointerEventKind.down {
                                        start-recording();
                                    }
                                    if event.kind == PointerEventKind.up {
                                        stop-recording();
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Session Review Tab
            if current-tab == 1 : VerticalLayout {
                spacing: 10px;
                padding: 10px;

                Text {
                    text: "📖 Session Review";
                    font-size: 16px;
                    font-weight: 700;
                    color: text-primary;
                }

                ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 8px;
                        padding: 4px;
                        alignment: start;

                        for sess in sessions : Rectangle {
                            background: assistant-bubble;
                            border-radius: 10px;
                            height: sess-layout.preferred-height + 24px;
                            padding-left: 12px;
                            padding-right: 12px;
                            padding-top: 10px;
                            padding-bottom: 10px;

                            sess-layout := VerticalLayout {
                                spacing: 4px;

                                HorizontalLayout {
                                    spacing: 12px;
                                    Text { text: "🗓 " + sess.started; font-size: 12px; font-weight: 700; color: text-primary; }
                                    Text { text: "📚 " + sess.level; font-size: 11px; font-weight: 700; color: accent-gold; }
                                    Text { text: "💬 " + sess.message-count + " msgs"; font-size: 11px; color: text-secondary; }
                                }

                                Text {
                                    text: "\"" + sess.preview + "\"";
                                    font-size: 11px;
                                    color: text-secondary;
                                    wrap: word-wrap;
                                }

                                HorizontalLayout {
                                    spacing: 8px;
                                    Button {
                                        text: "▶ Load";
                                        width: 80px;
                                        height: 28px;
                                        clicked => { load-session(sess.id); }
                                    }
                                    Button {
                                        text: "🗑 Delete";
                                        width: 80px;
                                        height: 28px;
                                        clicked => { delete-session(sess.id); }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            // Vocabulary Tab
            if current-tab == 2 : VerticalLayout {
                spacing: 10px;
                padding: 10px;

                Text {
                    text: "📊 Tracked Vocabulary (Spaced Repetition)";
                    font-size: 15px;
                    font-weight: 700;
                    color: text-primary;
                }

                // Header
                Rectangle {
                    height: 30px;
                    HorizontalLayout {
                        spacing: 4px;
                        Text { text: "Word"; font-size: 11px; font-weight: 700; color: text-secondary; horizontal-stretch: 1; }
                        Text { text: "Reading"; font-size: 11px; font-weight: 700; color: text-secondary; horizontal-stretch: 1; }
                        Text { text: "Struggles"; font-size: 11px; font-weight: 700; color: text-secondary; horizontal-stretch: 1; }
                        Text { text: "Next Review"; font-size: 11px; font-weight: 700; color: text-secondary; horizontal-stretch: 1; }
                    }
                }

                ScrollView {
                    vertical-stretch: 1;

                    VerticalLayout {
                        spacing: 2px;
                        alignment: start;

                        for word in vocab : Rectangle {
                            background: word.is-due ? #1a1a10 : transparent;
                            border-radius: 4px;
                            height: 28px;
                            padding-left: 4px;
                            padding-right: 4px;

                            HorizontalLayout {
                                spacing: 4px;
                                Text {
                                    text: word.word;
                                    font-size: 12px;
                                    color: word.is-due ? accent-gold : text-primary;
                                    horizontal-stretch: 1;
                                    vertical-alignment: center;
                                }
                                Text { text: word.reading; font-size: 12px; color: text-secondary; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: word.struggles; font-size: 12px; color: text-secondary; horizontal-stretch: 1; vertical-alignment: center; }
                                Text { text: word.next-review; font-size: 12px; color: text-secondary; horizontal-stretch: 1; vertical-alignment: center; }
                            }
                        }
                    }
                }
            }

            // Settings Tab
            if current-tab == 3 : VerticalLayout {
                spacing: 20px;
                padding: 20px;
                alignment: start;

                VerticalLayout {
                    spacing: 15px;
                    alignment: start;

                    Text { text: "🔑 Groq API Key"; font-size: 14px; font-weight: 700; color: text-primary; }

                    api-key-input := LineEdit {
                        placeholder-text: "gsk_...";
                        input-type: password;
                        height: 44px;
                        font-size: 14px;
                        accepted(text) => { save-api-key(text); }
                    }

                    Text {
                        text: "Get a free key → console.groq.com/keys";
                        font-size: 11px;
                        color: accent-green;
                    }

                    Rectangle { height: 1px; background: #1c1c3a; }

                    Text { text: "🎛 Engine Settings"; font-size: 14px; font-weight: 700; color: text-primary; }

                    Text { text: "Whisper Model: medium (configurable)"; font-size: 12px; color: text-secondary; }

                    Text { text: "Transcription Language: Japanese"; font-size: 12px; color: text-secondary; }

                    Text { text: "Device: auto (GPU if available)"; font-size: 12px; color: text-secondary; }
                }
            }
        }

        // Status bar
        Rectangle {
            background: #1a1a1a;
            height: 28px;

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;

                Text {
                    text: status-text;
                    font-size: 11px;
                    color: text-secondary;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Text {
                    text: "Whisper medium • LLM llama-3.3-70b • TTS VOICEVOX • " + japanese-ratio + "/30 ratio";
                    font-size: 10px;
                    color: #444466;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }
        }
    }
}